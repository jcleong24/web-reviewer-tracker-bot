# Copy this file to `.env` and fill in real values. `.env` is gitignored — never commit it.
#   cp .env.example .env   (or copy in Explorer)
#
# Consumed by BOTH:
#   - docker-compose.yml (Postgres container) — reads this file automatically
#   - the backend, via ./run-backend.ps1 which loads these into the environment

# --- PostgreSQL --------------------------------------------------------------
SPRING_DATASOURCE_USERNAME=webreviewer
SPRING_DATASOURCE_PASSWORD=change-me-to-a-strong-password
# Only override the URL if you're not using the local docker Postgres:
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/webreviewer

# --- Anthropic ---------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Optional — defaults to claude-opus-4-8 if unset:
# ANTHROPIC_MODEL=claude-opus-4-8
